# ==========================================
# MyHWManager Server Configuration
# ==========================================
# Copy this file to .env and customize the values.

# Admin credentials (used to create/reset the admin account on startup)
# The admin account is synced from these values EVERY time the server starts.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-something-strong

# JWT Secret — used to sign agent tokens for paired devices.
# IMPORTANT: Do NOT change this after devices are paired, or they will
# lose authentication and need to re-pair.
# Use a long random string (e.g., openssl rand -hex 32)
JWT_SECRET=myhwmanager-secret-change-in-production

# Server Port
SERVER_PORT=8080
